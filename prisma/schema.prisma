generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Novel {
  id         Int       @id @default(autoincrement())
  title      String
  author     String
  genre      String
  coverImage String    @default("/placeholder-cover.svg")
  views      Int       @default(0)
  rating     Float
  synopsis   String    @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  episodes   Episode[]
}

model Episode {
  id        Int    @id @default(autoincrement())
  novelId   Int
  novel     Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterNo Int
  title     String
  content   String @db.Text

  @@unique([novelId, chapterNo])
  @@index([novelId])
}

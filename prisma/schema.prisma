generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        String   @id
  email     String   @unique
  nickname  String?
  avatar    String?
  gender    String?
  age       Int?
  bio       String?
  isPrivate Boolean @default(false)
  isProfileComplete Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  novels    Novel[]  // 작가로서의 소설들
  readTags  UserTagRead[] // 읽은 태그 통계
  favorites UserFavorite[] // 선호작
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  color String @default("#6B7280") // 기본 회색

  // Relations
  novels NovelTag[]
  reads  UserTagRead[]
}

model Novel {
  id         Int       @id @default(autoincrement())
  title      String
  authorId   String    // Supabase User ID
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  genre      String
  coverImage String    @default("/placeholder-cover.svg")
  views      Int       @default(0)
  rating     Float     @default(0)
  synopsis   String
  ageRating  String    @default("전체 이용가")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  episodes   Episode[]
  notices    Notice[]      // 작가 공지사항
  tags       NovelTag[]
  favoritedBy UserFavorite[] // 선호하는 유저들
  comments   Comment[]     // 댓글들

  @@index([authorId])
  @@index([genre])
  @@index([updatedAt(sort: Desc)])
}

model Episode {
  id        Int     @id @default(autoincrement())
  novelId   Int
  novel     Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterNo Int
  isSideStory Boolean @default(false)
  title     String
  content   String
  image     String?
  authorNote String?
  views     Int      @default(0)
  recommends Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([novelId, chapterNo])
  @@index([novelId])
}

model NovelTag {
  novelId Int
  tagId   Int

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([novelId, tagId])
}

model UserTagRead {
  userId String
  tagId  Int
  count  Int @default(1) // 읽은 횟수

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
}

model UserFavorite {
  userId  String
  novelId Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@id([userId, novelId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  novelId   Int
  episodeId Int?
  userId    String
  userName  String
  content   String
  recommends Int     @default(0)
  dislikes  Int      @default(0)
  createdAt DateTime @default(now())

  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  votes     CommentVote[]

  @@index([novelId])
  @@index([episodeId])
  @@index([userId])
}

model CommentVote {
  userId    String
  commentId Int
  type      String   // "recommend" | "dislike"
  createdAt DateTime @default(now())

  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

model Report {
  id        Int      @id @default(autoincrement())
  type      String   // "COMMENT" | "NOVEL"
  targetId  Int
  userId    String
  reason    String
  createdAt DateTime @default(now())

  @@index([targetId])
  @@index([userId])
}
model Notice {
  id        Int      @id @default(autoincrement())
  novelId   Int
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  title     String
  content   String
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([novelId])
}
